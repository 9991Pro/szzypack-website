generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Inquiry {
  id             Int       @id @default(autoincrement())
  fullName       String    @map("full_name") @db.VarChar(100)
  companyName    String?   @map("company_name") @db.VarChar(200)
  email          String    @db.VarChar(200)
  phone          String?   @db.VarChar(50)
  whatsapp       String?   @db.VarChar(50)
  industry       String?   @db.VarChar(100)
  bagTypes       String[]  @map("bag_types")
  quantity       String?   @db.VarChar(100)
  specifications String?   @db.Text
  fileUrls       String[]  @map("file_urls")
  message        String?   @db.Text
  source         String?   @db.VarChar(100)
  sourceUrl      String?   @map("source_url") @db.VarChar(500)
  pageTitle      String?   @map("page_title") @db.VarChar(300)
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  isRead         Boolean   @default(false) @map("is_read")
  isReplied      Boolean   @default(false) @map("is_replied")
  repliedAt      DateTime? @map("replied_at")
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@index([isRead])
  @@map("inquiries")
}

model NewsletterSubscriber {
  id             Int       @id @default(autoincrement())
  email          String    @unique @db.VarChar(200)
  firstName      String?   @map("first_name") @db.VarChar(100)
  sourceUrl      String?   @map("source_url") @db.VarChar(500)
  isActive       Boolean   @default(true) @map("is_active")
  subscribedAt   DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([isActive])
  @@map("newsletter_subscribers")
}
